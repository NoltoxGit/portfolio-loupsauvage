# Force index.html as directory index
DirectoryIndex index.html index.htm index.php

<IfModule mod_rewrite.c>
  RewriteEngine On
  # If the request is for the root URL, serve index.html
  RewriteCond %{REQUEST_URI} ^/$
  RewriteRule ^$ /index.html [L]
</IfModule>

# Optional: disable MultiViews to avoid content negotiation issues
Options -MultiViews
DirectoryIndex index.php index.html

Redirect 301 /admin.html /admin/
Redirect 301 /admin/index.html /admin/
