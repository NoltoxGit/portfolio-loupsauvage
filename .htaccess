# =========================================================
# LoupSauvage Portfolio - Apache rules
# =========================================================
# Target hosting: WebStrator / Apache-compatible hosting.
# Keep this conservative. API PHP files must remain directly reachable under /api.

Options -Indexes
DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Do not rewrite existing files or directories.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Never route API calls to the React app.
    RewriteRule ^api/ - [L]

    # React/Vite fallback for clean public/admin routes, if enabled later.
    # If WebStrator has issues with clean routes, keep .html routes during phase 1.
    RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
