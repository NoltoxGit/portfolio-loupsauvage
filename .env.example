# =========================================================
# LoupSauvage Portfolio - Environment example
# =========================================================
# Copy this file to .env.local for local development if the PHP bootstrap later supports .env files.
# For the first PHP API implementation, prefer api/config/config.local.php created from config.example.php.

APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:5173
API_URL=http://localhost:8000/api

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=loupsauvage_portfolio
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

SESSION_NAME=loupsauvage_session
UPLOADS_PATH=uploads
MAX_UPLOAD_SIZE_MB=10
